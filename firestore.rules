rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function allowedReportEmails() {
      return get(/databases/$(database)/documents/appConfig/reportNotes).data.allowedEmails;
    }

    function isAllowedReportUser(userId) {
      return request.auth != null
        && request.auth.uid == userId
        && request.auth.token.email in allowedReportEmails();
    }

    match /appConfig/reportNotes {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.token.email in resource.data.allowedEmails;
    }

    match /reportBriefingNotes/{userId}/items/{noteId} {
      allow read, write: if isAllowedReportUser(userId);
    }
  }
}
