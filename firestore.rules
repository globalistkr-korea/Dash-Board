rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAllowedReportUser(userId) {
      return request.auth != null
        && request.auth.uid == userId
        && request.auth.token.email in ['globalistkr@gmail.com'];
    }

    match /reportBriefingNotes/{userId}/items/{noteId} {
      allow read, write: if isAllowedReportUser(userId);
    }
  }
}
